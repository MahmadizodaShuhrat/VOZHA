# Ин файлро нусхабардорӣ карда ба dart_defines.env номгузорӣ кунед
# ва қиматҳои воқеиро пур кунед.
# dart_defines.env ба .gitignore илова шудааст — онро ба git push накунед!

# Калиди OpenAI — аз platform.openai.com гиред
OPENAI_API_KEY=sk-proj-...

# WebSocket URL барои лобби (агар IP иваз шавад)
WS_LOBBY_URL=wss://api.vozhaomuz.com/api/v1/ws/public-rooms

# Azure Speech Services — барои pronunciation assessment
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastasia

# Resource access key
RESOURCE_SECRET=?key=your-resource-key

# --- Чӣ тавр истифода баред ---
# flutter run \
#   --dart-define=OPENAI_API_KEY=sk-proj-... \
#   --dart-define=WS_LOBBY_URL=wss://api.vozhaomuz.com/...
#
# Ё бо скрипт:
#   source dart_defines.env && flutter run $(cat dart_defines.env | grep -v '^#' | xargs -I{} echo --dart-define={})
