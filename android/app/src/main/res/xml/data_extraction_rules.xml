<?xml version="1.0" encoding="utf-8"?>
<!-- Disable cloud backup and device transfer to prevent stale SharedPreferences
     (progress_dirs, pending_progress_sync) from being restored on reinstall.
     This was causing a "same 4 repeat words" bug on certain tester devices. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
